# =============================================================================
# .gitignore — ignores generated files, local configs and editor artifacts
# to keep the repository clean, deterministic and free of local secrets.
# =============================================================================

# ---- Secrets / local configuration -------------------------------------------
.env
.env.*
!.env.example
tests/.env
*.pem
*.key
*.crt
secrets/
.secrets/
*-secret.yaml
.vault_pass
.vault_password
vault_pass.txt

# ---- Ansible -----------------------------------------------------------------
*.retry
.ansible/
collections/ansible_collections/
fact_cache/
/tmp/ansible_facts/

# ---- Ansible — inventories ---------------------------------------------------
# Versionados: manifest.yml, _shared/, overlays broetec-* e README.
# Overlays locais (cópias personalizadas) ficam gitignored.
provisioning/inventory/*
!provisioning/inventory/README.md
!provisioning/inventory/manifest.yml
!provisioning/inventory/_shared/
!provisioning/inventory/broetec-core/
!provisioning/inventory/broetec-storage/
!provisioning/inventory/broetec-monitor/

# ---- Lab KVM — discos, cache qcow2 e seed ISO (gerado por make up) -----------
# lab/README.md fica versionado; ver lab/README.md
lab/cache/
lab/disks/

# ---- Env — credenciais e defaults locais do laboratório (NUNCA commitar) -----
# A pasta `env/` guarda chave SSH, `.env` do Make, passwords, etc. Versionamos
# apenas README.md e `.env.example`.
env/*
!env/README.md
!env/.env.example
!env/ssh_config_lab.example
env/.env

# ---- Kubernetes --------------------------------------------------------------
kubeconfig
kubeconfig.*
*.kubeconfig
**/kubeconfig.local.*

# ---- Terraform / OpenTofu ----------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.*.log
*.tfvars
!*.tfvars.example

# ---- Python — bytecode / runtime ---------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- Python — build / packaging ----------------------------------------------
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# ---- Python — installer logs -------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# ---- Python — tests / coverage -----------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
nosetests.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ---- Python — web frameworks (se usar sidecars / apps Python) ----------------
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache

# ---- Documentation builds -----------------------------------------------------
docs/_build/
doc/_build/
target/
/site

# ---- Notebooks / interactive shell -------------------------------------------
.ipynb_checkpoints
profile_default/
ipython_config.py

# ---- Virtual environments -----------------------------------------------------
.python-version
__pypackages__/
.venv/
venv/
ENV/
env.bak/
venv.bak/
venv*
pythonenv*

# ---- Python — tools / typing -------------------------------------------------
*.sage.py
.spyderproject
.spyproject
.ropeproject
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.prof

# ---- Node.js / front-end (ferramentas opcionais) ------------------------------
node_modules/
coverage/

# ---- Logs ---------------------------------------------------------------------
*.log

# ---- IDEs / editors ----------------------------------------------------------
.vscode/
*.code-workspace
.idea/
*.iws
*.iml
*.ipr
cmake-build-*/
out/
.history
.ionide
.run*
*.swp
*.swo
*~
*.tmp
*.bak
local.properties
.settings/

# ---- General project artifacts ------------------------------------------------
ignore/
ignore

# ---- OS files ----------------------------------------------------------------
.DS_Store
*.DS_Store
Thumbs.db

