# =============================================================================
# .gitignore — ignores generated files, local configs and editor artifacts
# to keep the repository clean, deterministic and free of local secrets.
# =============================================================================

# ---- Secrets / local configuration -------------------------------------------
.env
.env.*
!.env.example
tests/.env
*.pem
*.key
*.crt
secrets/
.secrets/
*-secret.yaml
.vault_pass
.vault_password
vault_pass.txt

# ---- Ansible -----------------------------------------------------------------
*.retry
.ansible/
collections/ansible_collections/
fact_cache/
/tmp/ansible_facts/

# ---- Ansible — inventories (versiona apenas o overlay "example") -------------
# Cada utilizador deve copiar `provisioning/inventory/example` para um overlay
# próprio (ex.: `provisioning/inventory/meu-ambiente`). O padrão abaixo ignora
# todos os overlays e re-inclui apenas o "example", que é a Reference
# Architecture oficial da Broetec.
provisioning/inventory/*
!provisioning/inventory/example/

# ---- Env — credenciais locais do laboratório (NUNCA commitar) ---------------
# A pasta `env/` guarda a chave SSH gerada por `make keys` / `make up`. Cada
# clone do repositório usa a sua própria chave. Versionamos apenas o README
# que explica o que vai ali.
env/*
!env/README.md

# ---- Kubernetes --------------------------------------------------------------
kubeconfig
kubeconfig.*
*.kubeconfig
**/kubeconfig.local.*

# ---- Terraform / OpenTofu ----------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.*.log
*.tfvars
!*.tfvars.example

# ---- Python — bytecode / runtime ---------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- Python — build / packaging ----------------------------------------------
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# ---- Python — installer logs -------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# ---- Python — tests / coverage -----------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
nosetests.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ---- Python — web frameworks (se usar sidecars / apps Python) ----------------
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache

# ---- Documentation builds -----------------------------------------------------
docs/_build/
doc/_build/
target/
/site

# ---- Notebooks / interactive shell -------------------------------------------
.ipynb_checkpoints
profile_default/
ipython_config.py

# ---- Virtual environments -----------------------------------------------------
.python-version
__pypackages__/
.venv/
venv/
ENV/
env.bak/
venv.bak/
venv*
pythonenv*

# ---- Python — tools / typing -------------------------------------------------
*.sage.py
.spyderproject
.spyproject
.ropeproject
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.prof

# ---- Node.js / front-end (ferramentas opcionais) ------------------------------
node_modules/
coverage/

