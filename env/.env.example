# =============================================================================
# Defaults locais do k8s-blueprint (Make)
# =============================================================================
# Copie nesta pasta:
#   cp env/.env.example env/.env
#
# O Makefile carrega env/.env com -include (gitignored).
# A linha de comando continua a ter prioridade: make up VM_IP=10.20.30.50
# =============================================================================

# --- Inventário / VM -----------------------------------------------------------
OVERLAY=example
VM_NAME=broetec
VM_IP=10.20.30.40
KVM_NETWORK=broetec-lab
# Discos e cache qcow2 no repo (gitignored). Omita para usar o padrão abaixo.
# LIBVIRT_PATH=./var/libvirt
# LIBVIRT_POOL_PATH=$(LIBVIRT_PATH)/disks
# LIBVIRT_CACHE_PATH=$(LIBVIRT_PATH)/cache

# --- Ansible / Python ----------------------------------------------------------
UP_SPLIT=1
ANSIBLE_FORKS=1
UV_PYTHON=3.12

# --- SSH no controlador (libssh / avisos no terminal) ------------------------
# false (padrão): só $HOME/.ssh/known_hosts — não altera /etc/ssh no controlador.
# true: antes do `make up`, cria /etc/ssh/ssh_known_hosts vazio com sudo (opt-in).
#       Pode reduzir "ssh_strict_fopen" do libssh em distros sem esse ficheiro.
CREATE_SSH_GLOBAL_KNOWN_HOSTS=false
