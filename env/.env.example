# =============================================================================
# Defaults locais do k8s-blueprint (Make)
# =============================================================================
# Copie nesta pasta:
#   cp env/.env.example env/.env
#
# O Makefile carrega env/.env com -include (gitignored).
# A linha de comando continua a ter prioridade: make up OVERLAY=broetec-storage
# =============================================================================

# --- Inventário / overlay ------------------------------------------------------
# Overlay activo (default: broetec-core @ 10.20.30.40)
OVERLAY=broetec-core
# Opcional: sobrescreve a VM do overlay ao correr make inventory
# VM_NAME=broetec-core
# VM_IP=10.20.30.40
KVM_NETWORK=broetec-lab
# LAB_PATH=./lab

# --- Host KVM (role 00) --------------------------------------------------------
# true (default): instala pacotes libvirt no host (Fedora/RHEL mutável).
# false: só rede libvirt — use se o host já tem KVM instalado
#        (ex.: Silverblue/immutable, ou servidor já preparado).
KVM_HOST_BOOTSTRAP=true

# false (default): não altera firewall do host.
# true: detecta firewalld/ufw/iptables activo e aplica regras NAT/FORWARD
#       para VMs lab (necessário em hosts com Docker + firewall activo).
KVM_HOST_FIREWALL=false

# --- Ansible / Python ----------------------------------------------------------
ANSIBLE_FORKS=1
UV_PYTHON=3.14

# --- Fluxos Make (referência) --------------------------------------------------
# 1ª vez (role 00): make setup-host
# Uma VM:         make up                          # broetec-core (default)
# Outra VM:       make up OVERLAY=broetec-storage
# Todas as VMs:   make up-all
# Só k8s:         make deploy OVERLAY=broetec-core
# Sem bootstrap:  KVM_HOST_BOOTSTRAP=false em env/.env (ou na linha de comando)

# --- SSH no controlador --------------------------------------------------------
CREATE_SSH_GLOBAL_KNOWN_HOSTS=false
