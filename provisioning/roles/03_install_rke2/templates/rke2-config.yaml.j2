# /etc/rancher/rke2/config.yaml
# Managed by Ansible — role 03_install_rke2. Do not edit manually.
# Reference: https://docs.rke2.io/reference/server_config
---
write-kubeconfig-mode: "{{ rke2_write_kubeconfig_mode }}"
cni: {{ rke2_cni }}
disable-kube-proxy: {{ rke2_disable_kube_proxy | lower }}
node-name: "{{ rke2_node_name }}"
node-ip: "{{ rke2_node_ip }}"
advertise-address: "{{ rke2_advertise_address }}"
secrets-encryption: {{ rke2_secrets_encryption | lower }}

tls-san:
  - "{{ rke2_node_name }}"
  - "{{ rke2_node_ip }}"
{% for san in rke2_tls_san %}
  - "{{ san }}"
{% endfor %}

{% if rke2_disable | length > 0 %}
disable:
{% for item in rke2_disable %}
  - {{ item }}
{% endfor %}
{% endif %}

etcd-snapshot-schedule-cron: "{{ rke2_etcd_snapshot_schedule_cron }}"
etcd-snapshot-retention: {{ rke2_etcd_snapshot_retention }}
etcd-snapshot-compress: {{ rke2_etcd_snapshot_compress | lower }}

