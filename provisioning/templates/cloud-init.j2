#cloud-config
# =============================================================================
# cloud-init — user-data + meta-data (seed ISO NoCloud)
# =============================================================================
# Este template é renderizado pela role `kvm_vm` para cada host do grupo
# `vms` e gravado como `user-data` no seed ISO (NoCloud datasource).
#
# IP vem da reserva DHCP no dnsmasq da rede libvirt (MAC fixo -> vm_ip).
#
# Variáveis injetadas pela role:
#   - vm_hostname           : hostname curto (ex.: node-01)
#   - vm_ip                 : IP estático da VM (ex.: 10.20.30.40)
#   - base_domain           : domínio base (ex.: local.broetec.com.br)
#   - kvm_network.*         : prefix, gateway, dns_servers
#   - cloud_init.*          : default_user, timezone, locale, ssh_authorized_keys,
#                             password_hash opcional (SHA-512), ssh_password_login
# =============================================================================

{% set _pwd = cloud_init.password_hash | default('') %}
{% set _ssh_pwd_opt = cloud_init.ssh_password_login | default(none) %}

hostname: {{ vm_hostname }}
fqdn: {{ vm_hostname }}.{{ base_domain }}
prefer_fqdn_over_hostname: true
preserve_hostname: false
manage_etc_hosts: false

timezone: {{ cloud_init.timezone }}
locale: {{ cloud_init.locale }}

users:
  - name: {{ cloud_init.default_user }}
    gecos: "Broetec lab default user"
    groups: [wheel, adm, systemd-journal]
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    shell: /bin/bash
{% if _pwd | length > 0 %}
    lock_passwd: false
    passwd: "{{ _pwd }}"
{% else %}
    lock_passwd: true
{% endif %}
    ssh_authorized_keys:
{% for key in cloud_init.ssh_authorized_keys %}
      - "{{ key }}"
{% endfor %}

{# SSH por palavra-passe: só se definires password_hash; podes forçar false em ssh_password_login #}
ssh_pwauth: {% if _pwd | length == 0 %}false{% elif _ssh_pwd_opt is not none %}{{ _ssh_pwd_opt | lower }}{% else %}true{% endif %}
disable_root: true

write_files:
  # -------------------------------------------------------------------------
  # /etc/hosts — resolve o FQDN da própria VM no domínio Broetec.
  # -------------------------------------------------------------------------
  - path: /etc/hosts
    permissions: "0644"
    owner: root:root
    content: |
      127.0.0.1   localhost localhost.localdomain
      ::1         localhost6 localhost6.localdomain
      {{ vm_ip }}   {{ vm_hostname }}.{{ base_domain }} {{ vm_hostname }}

runcmd:
  - [ hostnamectl, set-hostname, "{{ vm_hostname }}.{{ base_domain }}" ]

final_message: "cloud-init concluído em {{ vm_hostname }}.{{ base_domain }} ({{ vm_ip }}) após $UPTIME segundos."
