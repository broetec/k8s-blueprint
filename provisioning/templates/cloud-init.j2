#cloud-config
# =============================================================================
# cloud-init — user-data + meta-data (NoCloud seed ISO)
# =============================================================================
# Rendered by role `01_create_vm` for each host in group `vms` and written as
# `user-data` on the seed ISO (NoCloud datasource).
#
# Interface IP: network-config on the same seed ISO (static by MAC; see network-config.j2).
#
# Variables injected by the role:
#   - vm_hostname           : short hostname (e.g. broetec-core)
#   - vm_ip                 : static VM IP (e.g. 10.20.30.40)
#   - base_domain           : base domain (e.g. local.broetec.com.br)
#   - kvm_network.*         : prefix, gateway, dns_servers
#   - cloud_init.*          : default_user, timezone, locale, ssh_authorized_keys,
#                             password_hash (SHA-512), ssh_password_login,
#                             sudo_nopasswd (passwordless sudo for Ansible)
# =============================================================================

{% set _pwd = cloud_init.password_hash | default('') %}
{% set _ssh_pwd_opt = cloud_init.ssh_password_login | default(none) %}
{% set _ssh_pwauth = false if (_pwd | length == 0) else ((_ssh_pwd_opt if _ssh_pwd_opt is not none else false) | bool) %}

hostname: {{ vm_hostname }}
fqdn: {{ vm_hostname }}.{{ base_domain }}
prefer_fqdn_over_hostname: true
preserve_hostname: false
manage_etc_hosts: false

timezone: {{ cloud_init.timezone }}
locale: {{ cloud_init.locale }}

users:
  - name: {{ cloud_init.default_user }}
    gecos: "Broetec lab default user"
    groups: [wheel, adm, systemd-journal]
{% if cloud_init.sudo_nopasswd | default(false) %}
    sudo: "ALL=(ALL) NOPASSWD:ALL"
{% else %}
    sudo: "ALL=(ALL) ALL"
{% endif %}
    shell: /bin/bash
{% if _pwd | length > 0 %}
    lock_passwd: false
    passwd: "{{ _pwd }}"
{% else %}
    lock_passwd: true
{% endif %}
    ssh_authorized_keys:
{% for key in cloud_init.ssh_authorized_keys %}
      - "{{ key }}"
{% endfor %}

{# ssh_pwauth: affects SSH service only. SPICE/VNC console uses local user password. #}
ssh_pwauth: {{ _ssh_pwauth | bool | ternary('true', 'false') }}
disable_root: true

write_files:
  # -------------------------------------------------------------------------
  # /etc/hosts — resolve this VM's FQDN on the Broetec lab domain.
  # -------------------------------------------------------------------------
  - path: /etc/hosts
    permissions: "0644"
    owner: root:root
    content: |
      127.0.0.1   localhost localhost.localdomain
      ::1         localhost6 localhost6.localdomain
      {{ vm_ip }}   {{ vm_hostname }}.{{ base_domain }} {{ vm_hostname }}

runcmd:
  - [ hostnamectl, set-hostname, "{{ vm_hostname }}.{{ base_domain }}" ]

final_message: "cloud-init finished on {{ vm_hostname }}.{{ base_domain }} ({{ vm_ip }}) after $UPTIME seconds."
