# =============================================================================
# cloud-init network-config v2 — ficheiro à parte no seed NoCloud (ISO cidata)
# =============================================================================
# Aplicado na fase «network» do cloud-init, antes do SSH — mais fiável em
# Generic Cloud do que apenas um keyfile do NetworkManager em write_files.
# Variáveis: vm_ip, kvm_network.*, base_domain
# =============================================================================
version: 2
ethernets:
  lab0:
    dhcp4: false
    dhcp6: false
    match:
      driver: virtio_net
    addresses:
      - {{ vm_ip }}/{{ kvm_network.prefix }}
    routes:
      - to: default
        via: {{ kvm_network.gateway }}
    nameservers:
      addresses:
{% for ns in kvm_network.dns_servers %}
        - {{ ns }}
{% endfor %}
      search:
        - {{ base_domain }}
